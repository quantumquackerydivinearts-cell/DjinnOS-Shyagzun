{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantumquackery.org/schemas/wand_damage_attestation.schema.json",
  "title": "Wand Damage Attestation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_family",
    "schema_version",
    "wand_id",
    "notifier_id",
    "damage_state",
    "media"
  ],
  "properties": {
    "schema_family": {
      "const": "wand_damage_attestation"
    },
    "schema_version": {
      "const": "v1"
    },
    "wand_id": {
      "type": "string",
      "minLength": 1
    },
    "notifier_id": {
      "type": "string",
      "minLength": 1
    },
    "event_tag": {
      "type": [
        "string",
        "null"
      ]
    },
    "damage_state": {
      "type": "string",
      "enum": [
        "worn",
        "chipped",
        "cracked",
        "broken",
        "restored",
        "retired"
      ]
    },
    "media": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/media_evidence"
      }
    },
    "payload": {
      "type": "object"
    }
  },
  "$defs": {
    "media_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "filename",
        "mime_type"
      ],
      "properties": {
        "filename": {
          "type": "string",
          "minLength": 1
        },
        "mime_type": {
          "type": "string",
          "enum": [
            "image/heic",
            "image/heif",
            "image/jpeg",
            "image/png",
            "image/webp"
          ]
        },
        "sha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "size_bytes": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "capture_timestamp": {
          "type": [
            "string",
            "null"
          ]
        },
        "feature_digest": {
          "type": [
            "string",
            "null"
          ]
        },
        "metadata_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "transcoded_from_mime": {
          "type": [
            "string",
            "null"
          ]
        },
        "width": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "height": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        }
      }
    }
  }
}

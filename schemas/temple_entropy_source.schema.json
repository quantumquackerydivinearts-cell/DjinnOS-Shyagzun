{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantumquackery.org/schemas/temple_entropy_source.schema.json",
  "title": "Temple Entropy Source",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_family",
    "schema_version",
    "provenance_id",
    "source_type",
    "state_digest"
  ],
  "properties": {
    "schema_family": { "const": "temple_entropy_source" },
    "schema_version": { "const": "v1" },
    "provenance_id": { "type": "string", "minLength": 1 },
    "source_type": { "type": "string", "minLength": 1 },
    "garden_id": { "type": ["string", "null"] },
    "plot_id": { "type": ["string", "null"] },
    "state_digest": { "type": "string", "minLength": 1 },
    "observation_digest": { "type": ["string", "null"] },
    "capture_mode": { "type": ["string", "null"] },
    "metadata": { "type": "object" }
  }
}

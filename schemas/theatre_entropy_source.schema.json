{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantumquackery.org/schemas/theatre_entropy_source.schema.json",
  "title": "Theatre Entropy Source",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_family",
    "schema_version",
    "provenance_id",
    "source_type",
    "media_digest"
  ],
  "properties": {
    "schema_family": { "const": "theatre_entropy_source" },
    "schema_version": { "const": "v1" },
    "provenance_id": { "type": "string", "minLength": 1 },
    "source_type": { "type": "string", "minLength": 1 },
    "performance_id": { "type": ["string", "null"] },
    "upload_id": { "type": ["string", "null"] },
    "media_digest": { "type": "string", "minLength": 1 },
    "feature_digest": { "type": ["string", "null"] },
    "metadata": { "type": "object" }
  }
}

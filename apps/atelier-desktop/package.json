{
  "name": "atelier-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "set ELECTRON_RUN_AS_NODE=&& concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "start": "electron .",
    "build": "vite build",
    "build:web": "vite build",
    "clean:desktop": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path dist) { Remove-Item -Recurse -Force dist }; if (Test-Path release\\\\desktop) { Remove-Item -Recurse -Force release\\\\desktop }\"",
    "rebuild:desktop": "npm run clean:desktop && npm run build:web",
    "pack:desktop:dir": "npm run rebuild:desktop && npx electron-builder --dir",
    "pack:desktop:win": "npm run rebuild:desktop && npx electron-builder --win portable nsis",
    "test": "vitest run",
    "preview": "vite preview",
    "mobile:android:init": "npx cap add android",
    "mobile:sync": "npm run build:web && npx cap sync",
    "mobile:open:android": "npx cap open android",
    "mobile:run:android": "npm run mobile:sync && npx cap run android"
  },
  "dependencies": {
    "@capacitor/core": "^6.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/cli": "^6.2.0",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.quantumquackery.atelier.desktop",
    "productName": "Atelier Desktop",
    "directories": {
      "output": "release/desktop",
      "buildResources": "public"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "asar": true,
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "icon": "public/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "portable",
        "nsis"
      ],
      "artifactName": "atelier-desktop-${version}-${arch}.${ext}"
    },
    "linux": {
      "icon": "public/icon.png"
    },
    "mac": {
      "icon": "public/icon.png"
    }
  }
}

# Quantum Quackery Atelier API — environment variables
# Copy to .env and fill in secrets before running.

# ── Required secrets ──────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG
WAND_MASTER_SECRET=CHANGE_ME_WAND_MASTER_SECRET_32_CHARS

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, good for local dev):
DATABASE_URL=sqlite+aiosqlite:///./atelier.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/atelier

# ── Redis (optional, for distributed tick state) ──────────────────────────────
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# ── Server ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ── CORS (space-separated or JSON list) ──────────────────────────────────────
# Add your frontend origins here
CORS_ORIGINS=["http://localhost:3000","http://localhost:5179","https://quantumquackery.org"]

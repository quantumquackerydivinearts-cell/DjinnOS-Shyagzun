{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantumquackery.org/schemas/guild_message_envelope.schema.json",
  "title": "Guild Message Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_family",
    "schema_version",
    "cipher_family",
    "guild_id",
    "channel_id",
    "sender_id",
    "wand_id",
    "ciphertext_b64",
    "nonce_b64",
    "mac_hex",
    "derivation"
  ],
  "properties": {
    "schema_family": { "const": "guild_message_envelope" },
    "schema_version": { "const": "v1" },
    "cipher_family": { "const": "experimental_hash_stream_v1" },
    "guild_id": { "type": "string", "minLength": 1 },
    "channel_id": { "type": "string", "minLength": 1 },
    "thread_id": { "type": ["string", "null"] },
    "sender_id": { "type": "string", "minLength": 1 },
    "wand_id": { "type": "string", "minLength": 1 },
    "ciphertext_b64": { "type": "string", "minLength": 1 },
    "nonce_b64": { "type": "string", "minLength": 1 },
    "mac_hex": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "metadata": { "type": "object" },
    "derivation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system_entropy_digest",
        "context_digest",
        "wand_digest",
        "attestation_media_digests"
      ],
      "properties": {
        "system_entropy_digest": { "type": "string", "minLength": 1 },
        "temple_entropy_digest": { "type": ["string", "null"] },
        "theatre_entropy_digest": { "type": ["string", "null"] },
        "context_digest": { "type": "string", "minLength": 1 },
        "wand_digest": { "type": "string", "minLength": 1 },
        "attestation_media_digests": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
